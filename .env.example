# =============================================================================
# DataSense — copy this file to `.env.local` and fill in your values.
# Never commit `.env.local` or share API keys in chat or git.
# =============================================================================

# --- data.gov.in (https://data.gov.in) ---
DATA_GOV_IN_API_KEY=your_data_gov_in_api_key

# Primary API base (resource id is appended: /{resource_id}?api-key=...)
DATA_GOV_IN_BASE_URL=https://api.data.gov.in/resource

# Legacy fallback if the primary host is slow or unavailable
DATA_GOV_IN_FALLBACK_URL=https://data.gov.in/api/datastore/resource.json

# Rows fetched per question (1–500)
DATA_GOV_IN_FETCH_LIMIT=80

# Request timeout in milliseconds
DATA_GOV_IN_TIMEOUT_MS=60000

# Optional: override 2011 Census resource UUIDs (sidebar keys: sales | crm | ops)
# Primary Census Abstract 2011 - India
# DATA_GOV_RESOURCE_SALES=0764657f-00ec-4c6b-9ece-2d7b8a7401fa
# Population by single year of age, residence and sex, 2011
# DATA_GOV_RESOURCE_CRM=3fac8061-9b36-418d-a5d5-7cedd300c942
# Literacy & workers (same PCA resource; different prompt focus)
# DATA_GOV_RESOURCE_OPS=0764657f-00ec-4c6b-9ece-2d7b8a7401fa

# --- Groq (https://console.groq.com) ---
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=openai/gpt-oss-120b
GROQ_MAX_COMPLETION_TOKENS=2048
GROQ_TEMPERATURE=0.3
# Automatic retries when Groq returns HTTP 429 (0–5)
GROQ_RATE_LIMIT_MAX_RETRIES=3

# Max JSON characters from data.gov.in injected into the model prompt
CHAT_MAX_CONTEXT_CHARS=18000
