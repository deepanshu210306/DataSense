# =============================================================================
# DataSense — copy to `.env.local` and fill in your values.
# Never commit `.env.local` or share secrets in chat or git.
# =============================================================================

# --- data.gov.in (https://data.gov.in) ---
# One API key works for any resource_id on the platform.
DATA_GOV_IN_API_KEY=your_data_gov_in_api_key
DATA_GOV_IN_BASE_URL=https://api.data.gov.in/resource
DATA_GOV_IN_FALLBACK_URL=https://data.gov.in/api/datastore/resource.json
DATA_GOV_IN_FETCH_LIMIT=80
DATA_GOV_IN_TIMEOUT_MS=60000

# --- Groq (https://console.groq.com) ---
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=openai/gpt-oss-120b
GROQ_MAX_COMPLETION_TOKENS=1024
GROQ_TEMPERATURE=0.3
GROQ_RATE_LIMIT_MAX_RETRIES=3
# Input-token budget for system prompt + history (Groq on_demand ~8000/request)
GROQ_MAX_PROMPT_TOKENS=6500
CHAT_MAX_CONTEXT_CHARS=5000

# --- Auth (Auth.js v5 / NextAuth) ---
# Required for JWT session signing — generate: openssl rand -base64 32
AUTH_SECRET=your_auth_secret
# Canonical app URL (must match how you open the site in the browser)
AUTH_URL=http://localhost:3000
# Legacy alias — Auth.js v5 still reads this as a fallback; keep in sync with AUTH_URL
NEXTAUTH_URL=http://localhost:3000

# --- MongoDB (Mongoose) ---
# Atlas or self-hosted connection string
MONGODB_URI=mongodb+srv://user:password@cluster.example.mongodb.net/?retryWrites=true&w=majority
# Database name used for users, chats, and the datasets cache
MONGODB_DB_NAME=datasense
